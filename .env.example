# Supabase 연동 설정 (선택 — 없으면 로컬 데이터로 동작)
# 1. supabase.com 접속 → 프로젝트 생성
# 2. Project Settings → API → 아래 값 복사
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
VITE_PUBLIC_APP_URL=https://troiareuke-crm.vercel.app

# NAS 중앙 계정·비밀번호 재설정 API
# 기본 인증은 Supabase입니다. 계정 이전과 Supabase RLS 연동이 완료된 뒤에만
# VITE_AUTH_PROVIDER=nas 로 전환하세요.
VITE_AUTH_PROVIDER=supabase
VITE_AUTH_API_URL=https://crm-api.example.com

# Google Calendar 연동 (선택)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
