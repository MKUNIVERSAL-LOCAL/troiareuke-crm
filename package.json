{
  "name": "troiareuke-crm",
  "productName": "트로이아르케 CRM",
  "private": true,
  "version": "1.0.25",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "cross-env BUILD_TARGET=electron npm run build && electron-builder --win",
    "electron:build:portable": "cross-env BUILD_TARGET=electron npm run build && electron-builder --win portable",
    "electron:portable:prepare": "node scripts/prepare-portable-update.mjs",
    "electron:installer": "cross-env BUILD_TARGET=electron npm run build && electron-builder --win nsis",
    "electron:build:dir": "cross-env BUILD_TARGET=electron npm run build && electron-builder --win --dir",
    "electron:zip": "npm run electron:build:dir && powershell -Command \"Remove-Item -Path 'release\\트로이아르케-CRM.zip' -ErrorAction SilentlyContinue; Compress-Archive -Path 'release\\win-unpacked\\*' -DestinationPath 'release\\트로이아르케-CRM.zip'; Write-Host '✅ ZIP 완료: release/트로이아르케-CRM.zip'\"",
    "electron:release": "npm run build && electron-builder --win --publish always",
    "release:stage": "node scripts/stage-nas-update.mjs",
    "release:nas": "npm run electron:installer && npm run release:stage",
    "deploy": "cross-env DEPLOY_TARGET=ghpages npm run build && gh-pages -d dist",
    "test:nas-outbox": "node scripts/test-nas-outbox.mjs",
    "test:password-reset": "node scripts/test-password-reset.mjs",
    "test:photo-sync": "node scripts/test-photo-sync.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^8.0.0",
    "workbox-window": "^7.4.1"
  },
  "build": {
    "appId": "com.troiareuke.crm",
    "productName": "트로이아르케 CRM",
    "copyright": "Copyright © 2024 TROIAREUKE",
    "publish": {
      "provider": "generic",
      "url": "https://crm-update.mkcorp.familyds.com"
    },
    "electronUpdaterCompatibility": ">= 2.16",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "트로이아르케 CRM",
      "installerLanguages": [
        "ko_KR"
      ],
      "language": "1042"
    },
    "portable": {
      "artifactName": "트로이아르케 CRM.exe",
      "requestExecutionLevel": "user"
    }
  }
}
