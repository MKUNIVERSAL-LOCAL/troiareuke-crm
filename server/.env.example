POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://crm_auth:replace-with-a-long-random-password@database:5432/crm_auth
PUBLIC_BASE_URL=https://crm-api.example.com
ALLOWED_ORIGINS=http://localhost:5173,null
SESSION_DAYS=30
RESET_TOKEN_MINUTES=30
# DSM 역방향 프록시 뒤 = 1 (기본). 8787 직접 노출 시 반드시 0
TRUST_PROXY=1

# 계정 정책: 공개 가입 차단(관리자 발급제) + 최초 슈퍼어드민 계정
ALLOW_PUBLIC_SIGNUP=false
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# 메시지 발송사 (미설정 시 발송 안 됨 — pending으로 정직 기록)
# none = 미설정 / http = 범용 HTTP 중계 (엔포 등 발송사 계약 후 설정)
SMS_PROVIDER=none
SMS_HTTP_URL=
SMS_HTTP_KEY=
SMS_SENDER_ID=
MESSAGE_HOURLY_LIMIT=500

# 재방문 자동 리마인더 (발송사 설정 후 true로)
REMINDER_ENABLED=false
REMINDER_HOUR=10
REMINDER_CYCLE_DAYS=28
REMINDER_COOLDOWN_DAYS=7

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=crm@example.com
SMTP_PASS=replace-with-smtp-password
MAIL_FROM=트로이아르케 CRM <crm@example.com>
